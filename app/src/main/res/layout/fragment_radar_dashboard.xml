<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_panel_card"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_neon_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:text="Initializing V2V..."
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/modelOutputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_console_card"
            android:paddingHorizontal="10dp"
            android:paddingVertical="10dp"
            android:text="Model output initializing..."
            android:textColor="#B8D9FF"
            android:textSize="11sp"
            android:typeface="monospace" />
    </LinearLayout>

    <com.aryan.v2v.RadarView
        android:id="@+id/radarView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_panel_card" />

</LinearLayout>
